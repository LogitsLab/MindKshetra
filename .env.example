# Optional — copy to .env.local and fill values
# cp .env.example .env.local

# Groq API key for Ask Madhav chat and verse stories
# Get one at https://console.groq.com
GROQ_API_KEY=

# Optional model override (default: qwen/qwen3.6-27b)
# GROQ_MODEL=qwen/qwen3.6-27b

# Public site URL (used for metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Upstash Redis — required on Vercel for shared rate limits + story cache
# Create a free Redis DB at https://console.upstash.com → REST API
# Then in Vercel → Project → Settings → Environment Variables, set both:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Verify after deploy: GET /api/health → redis.reachable should be true
