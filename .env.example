# MindKshetra environment template
# Copy to .env.local (preferred) or .env and fill values:
#   cp .env.example .env.local

# =============================================================================
# REQUIRED (local Madhav chat + stories)
# =============================================================================

# Groq API key — Ask Madhav chat and verse story generation
# Get one at https://console.groq.com
GROQ_API_KEY=

# Public site URL (metadata / Open Graph / share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# OPTIONAL locally / REQUIRED on Vercel production
# =============================================================================

# Upstash Redis — shared rate limits + story cache across serverless instances
# Create at https://console.upstash.com → REST API
# Without these, each instance uses in-memory fallback (fine for local dev)
# Verify after deploy: GET /api/health → redis.reachable should be true
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# OPTIONAL — Supabase v2 (auth, DB content, chat persistence, favorites)
# Required when CONTENT_SOURCE=db or for account features
# Create a project at https://supabase.com
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — seed/migrate scripts only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Content source: json (default, no Supabase) or db (requires Supabase + seed)
# CONTENT_SOURCE=db

# =============================================================================
# OPTIONAL — Vector RAG (v2.1+)
# Required for hybrid semantic retrieval in Madhav when using DB
# Get a key at https://www.voyageai.com
# =============================================================================

VOYAGE_API_KEY=

# =============================================================================
# OPTIONAL
# =============================================================================

# Groq model override (default: qwen/qwen3.6-27b)
# GROQ_MODEL=qwen/qwen3.6-27b

# Nominatim User-Agent for birth-place geocoding (OpenStreetMap policy)
# NOMINATIM_USER_AGENT=MindKshetra/1.0 (astrology; contact: you@example.com)

# Apply supabase/migrations/007_astrology.sql for saved birth charts
# (npm run db:migrate, or run the SQL in the Supabase SQL editor)

# Email — Verse of the Day (optional)
# 1. Create an account at https://resend.com → API Keys → create key
# 2. For local testing, Resend allows sending only to your signup email
#    with from: MindKshetra <onboarding@resend.dev>
# 3. For production: Domains → add + verify your domain, then set RESEND_FROM
# 4. Apply supabase/migrations/004_user_prefs.sql (user email opt-out)
# 5. Restart the app. Account → Settings → toggle + “Email today’s verse”
RESEND_API_KEY=
RESEND_FROM=MindKshetra <onboarding@resend.dev>
