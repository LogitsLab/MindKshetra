# Groq API key for Ask Madhav chat and verse stories
# Get one at https://console.groq.com
GROQ_API_KEY=

# Optional model override (default: qwen/qwen3.6-27b)
# GROQ_MODEL=qwen/qwen3.6-27b

# Public site URL (used for metadata / Open Graph)
# Leave as localhost for local development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Upstash Redis for shared rate limits + story cache on Vercel
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
